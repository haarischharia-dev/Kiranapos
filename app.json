{
  "expo": {
    "name": "kiranapos",
    "slug": "kiranapos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kiranapos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/771c626d-9ef6-4135-83aa-d1d0e41c56ee",
      "checkAutomatically": "ON_LOAD",
      "enabled": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fff8f5",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.haarischharia.kiranapos",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fff8f5",
          "dark": {
            "backgroundColor": "#fff8f5"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow KiranaPOS to access your camera for barcode scanning."
        }
      ],
      [
        "@config-plugins/react-native-ble-plx",
        {
          "isConnectable": true
        }
      ],
      ["@sentry/react-native/expo", { "url": "https://sentry.io/", "project": "kiranapos", "organization": "haaris-nx" }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "771c626d-9ef6-4135-83aa-d1d0e41c56ee"
      }
    }
  }
}
