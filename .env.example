EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For `npm run db:push` — Session pooler URI (Dashboard → Connect → Session pooler, port 5432)
# SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Or password + region instead of SUPABASE_DB_URL:
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_REGION=ap-south-1

# For `npm run functions:deploy` — Dashboard → Account → Access Tokens
# SUPABASE_ACCESS_TOKEN=sbp_your_token_here
